  OBS
      LAYER nwell ;
        RECT 5.330 10.795 45.270 49.045 ;
      LAYER li1 ;
        RECT 5.520 10.795 45.080 49.045 ;
      LAYER met1 ;
        RECT 1.910 6.500 49.610 49.200 ;
      LAYER met2 ;
        RECT 1.930 0.560 49.590 49.145 ;
