      LAYER met3 ;
        RECT 50.315 24.520 50.915 25.120 ;
    END
  END addr[3]
  PIN clk
    DIRECTION INPUT ;
    USE SIGNAL ;
    ANTENNAGATEAREA 0.213000 ;
    PORT
      LAYER met3 ;
        RECT 50.315 27.240 50.915 27.840 ;
    END
  END clk
  PIN mux
    DIRECTION OUTPUT ;
    USE SIGNAL ;
    ANTENNADIFFAREA 0.702900 ;
    PORT
      LAYER met3 ;
        RECT 50.315 29.960 50.915 30.560 ;
    END
  END mux
  PIN q
    DIRECTION OUTPUT ;
    USE SIGNAL ;
